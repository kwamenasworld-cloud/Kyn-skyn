    opacity: 0.45;
    padding: 0.35rem 0;
    border-top: 1px solid rgba(255, 244, 206, 0.08);
  }

  .th-card__symptoms li:last-child {
    border-bottom: 1px solid rgba(255, 244, 206, 0.08);
  }

  /* ========== HOW IT WORKS ========== */
  .th-steps {
    padding: 6rem 3rem;
    background: var(--dark);
  }

  .th-steps__container {
    max-width: 64rem;
    margin: 0 auto;
    text-align: center;
  }

  .th-steps__eyebrow {
    font-family: var(--font-accent);
    font-size: 0.75rem;
    letter-spacing: 0.15em;
    text-transform: uppercase;
    color: var(--cream);
    opacity: 0.5;
    margin-bottom: 1.5rem;
  }

  .th-steps__heading {
    font-family: var(--font-serif);
    font-size: clamp(1.8rem, 4vw, 2.8rem);
    font-weight: 300;
    color: var(--cream);
    margin-bottom: 4rem;
  }

  .th-steps__grid {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: 2rem;
    text-align: left;
