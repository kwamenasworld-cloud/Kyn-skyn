<style>
  /* ========== TELEHEALTH HERO ========== */
  .th-hero {
    background: var(--dark);
    padding: 10rem 3rem 5rem;
    text-align: center;
    position: relative;
    overflow: hidden;
  }

  .th-hero__molecule {
    position: absolute;
    top: 50%;
    left: 50%;
    transform: translate(-50%, -50%);
    width: 40rem;
    height: 40rem;
    opacity: 0.04;
    pointer-events: none;
  }

  .th-hero__eyebrow {
    font-family: var(--font-accent);
    font-size: 0.75rem;
    letter-spacing: 0.15em;
    text-transform: uppercase;
    color: var(--cream);
    opacity: 0.5;
    margin-bottom: 1.5rem;
  }

  .th-hero__heading {
    font-family: var(--font-serif);
    font-size: clamp(2.2rem, 5vw, 3.8rem);
    font-weight: 300;
    color: var(--cream);
    line-height: 1.15;
    max-width: 48rem;
    margin: 0 auto 1.5rem;
  }

  .th-hero__desc {
    font-family: var(--font-sans);
    font-size: 1rem;
    color: var(--cream);
    opacity: 0.6;
    line-height: 1.7;
    max-width: 36rem;
    margin: 0 auto 2.5rem;
  }

  .th-hero__cta {
    display: inline-block;
    font-family: var(--font-sans);
    font-size: 0.85rem;
    font-weight: 600;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color: var(--cream);
    background: var(--button);
    padding: 1rem 2.5rem;
    border-radius: 2px;
    text-decoration: none;
    transition: background 0.3s;
  }

  .th-hero__cta:hover { background: var(--maroon); }

  /* ========== CONDITIONS ========== */
  .th-conditions {
    padding: 6rem 3rem;
    background: var(--cream);
  }

  .th-conditions__container {
    max-width: 64rem;
    margin: 0 auto;
    text-align: center;
  }

  .th-conditions__eyebrow {
    font-family: var(--font-accent);
    font-size: 0.75rem;
    letter-spacing: 0.15em;
    text-transform: uppercase;
    color: var(--maroon);
    opacity: 0.5;
    margin-bottom: 1.5rem;
  }

  .th-conditions__heading {
    font-family: var(--font-serif);
