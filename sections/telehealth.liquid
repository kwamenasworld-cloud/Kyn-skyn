  }

  .th-step__num {
    font-family: var(--font-serif);
    font-size: 3rem;
    font-weight: 300;
    color: var(--gold);
    opacity: 0.3;
    line-height: 1;
    margin-bottom: 1rem;
  }

  .th-step__title {
    font-family: var(--font-sans);
    font-size: 0.95rem;
    font-weight: 600;
    color: var(--cream);
    margin-bottom: 0.5rem;
  }

  .th-step__desc {
    font-family: var(--font-sans);
    font-size: 0.8rem;
    color: var(--cream);
    opacity: 0.5;
    line-height: 1.7;
  }

  /* ========== CTA SECTION ========== */
  .th-cta {
    padding: 6rem 3rem;
    background: var(--cream);
    text-align: center;
  }

  .th-cta__container {
    max-width: 40rem;
    margin: 0 auto;
  }

  .th-cta__heading {
    font-family: var(--font-serif);
    font-size: clamp(1.8rem, 4vw, 2.8rem);
    font-weight: 300;
    color: var(--maroon);
    margin-bottom: 1rem;
  }

  .th-cta__desc {
    font-family: var(--font-sans);
    font-size: 1rem;
    color: var(--maroon);
    opacity: 0.6;
    line-height: 1.7;
    margin-bottom: 2.5rem;
  }

  .th-cta__button {
    display: inline-block;
    font-family: var(--font-sans);
    font-size: 0.85rem;
    font-weight: 600;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color: var(--cream);
    background: var(--button);
    padding: 1rem 2.5rem;
    border-radius: 2px;
    text-decoration: none;
    transition: background 0.3s;
  }

  .th-cta__button:hover { background: var(--maroon); }

  .th-cta__note {
    font-family: var(--font-sans);
    font-size: 0.75rem;
    color: var(--maroon);
    opacity: 0.4;
    margin-top: 1.5rem;
    line-height: 1.6;
  }

  /* ========== FAQ ========== */
  .th-faq {
    padding: 6rem 3rem;
    background: var(--dark);
  }

  .th-faq__container {
    max-width: 48rem;
    margin: 0 auto;
  }

  .th-faq__heading {
    font-family: var(--font-serif);
    font-size: clamp(1.8rem, 4vw, 2.8rem);
    font-weight: 300;
    color: var(--cream);
    text-align: center;
    margin-bottom: 3rem;
  }

  .th-faq__item {
    border-bottom: 1px solid rgba(255, 244, 206, 0.1);
    padding: 1.5rem 0;
  }

  .th-faq__q {
    font-family: var(--font-sans);
    font-size: 0.95rem;
    font-weight: 600;
    color: var(--cream);
    cursor: pointer;
    display: flex;
    justify-content: space-between;
    align-items: center;
    background: none;
    border: none;
    width: 100%;
    text-align: left;
    padding: 0;
  }

  .th-faq__q::after {
    content: '+';
    font-size: 1.2rem;
    color: var(--gold);
    flex-shrink: 0;
    margin-left: 1rem;
    transition: transform 0.3s;
  }

  .th-faq__q.active::after {
    content: '\2212';
  }

  .th-faq__a {
    font-family: var(--font-sans);
    font-size: 0.85rem;
    color: var(--cream);
    opacity: 0.5;
    line-height: 1.7;
    max-height: 0;
    overflow: hidden;
    transition: max-height 0.3s ease, padding 0.3s ease;
  }

  .th-faq__a.open {
    max-height: 20rem;
    padding-top: 1rem;
  }

  /* ========== RESPONSIVE ========== */
  @media (max-width: 768px) {
    .th-hero { padding: 8rem 1.5rem 3rem; }
    .th-conditions { padding: 4rem 1.5rem; }
    .th-conditions__grid { grid-template-columns: 1fr; }
    .th-steps { padding: 4rem 1.5rem; }
    .th-steps__grid { grid-template-columns: 1fr 1fr; gap: 2.5rem; }
    .th-cta { padding: 4rem 1.5rem; }
    .th-faq { padding: 4rem 1.5rem; }
  }

  @media (max-width: 480px) {
    .th-steps__grid { grid-template-columns: 1fr; }
