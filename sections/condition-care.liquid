    .cc-hero { padding: 6rem 1.5rem 4rem; }
    .cc-trust { padding: 1.5rem; }
    .cc-trust__container { gap: 1rem 1.5rem; }
    .cc-trust__item { font-size: 0.7rem; }
    .cc-what { padding: 4rem 1.5rem; }
    .cc-symptoms { padding: 4rem 1.5rem; }
    .cc-treatment { padding: 4rem 1.5rem; }
    .cc-treatment__container { grid-template-columns: 1fr; gap: 2rem; }
    .cc-pricing { padding: 4rem 1.5rem; }
    .cc-process { padding: 4rem 1.5rem; }
    .cc-process__grid { grid-template-columns: 1fr 1fr; gap: 1rem; }
    .cc-faq { padding: 4rem 1.5rem; }
    .cc-final { padding: 5rem 1.5rem; }
  }

  @media (max-width: 520px) {
    .cc-process__grid { grid-template-columns: 1fr; }
  }
</style>

