<div class="contact-page">
  <section class="contact">
    <div class="contact__container fade-in">
      <p class="contact__eyebrow">Get in touch</p>
      <h2 class="contact__heading">How can we help?</h2>
      <p class="contact__desc">Customer questions, press, brand collaborations, retail inquiries. Start here. Most messages get a reply within 1-2 business days.</p>

      <div class="contact__type-selector">
        <button class="contact__type-btn active" data-type="customer" type="button">Customer support</button>
        <button class="contact__type-btn" data-type="press" type="button">Press / Creator</button>
        <button class="contact__type-btn" data-type="retailer" type="button">Retailer / Stockist</button>
      </div>

      <form class="contact__form" id="contactForm">
        <input type="hidden" name="access_key" value="247dfa8d-cc76-4f13-ae64-e916737ac782">
        <input type="hidden" name="from_name" value="Kyn Skyn Website">
        <input type="hidden" id="contactSubject" name="subject" value="Customer Support">
        <div class="contact__row">
          <input class="contact__field" type="text" name="name" placeholder="Your name" aria-label="Your name" required>
          <input class="contact__field" type="email" name="email" placeholder="Email address" aria-label="Email address" required>
        </div>
        <input class="contact__field" type="text" name="company" placeholder="Company / Brand / Handle (if applicable)" aria-label="Company, brand, or handle">
        <textarea class="contact__field" name="message" placeholder="Tell us what's going on. For order issues, please include your order number." aria-label="Your message" required></textarea>
        <button class="contact__submit" type="submit">Send Message</button>
        <p class="contact__confirmation" id="contactConfirmation">Message sent. Most messages get a reply within 1-2 business days.</p>
      </form>
    </div>
  </section>
</div>

<script>
  // Contact form - type selector
  const typeBtns = document.querySelectorAll('.contact__type-btn');
  const contactSubject = document.getElementById('contactSubject');
  const subjectMap = {
    customer: 'Customer Support',
    press: 'Press / Creator Inquiry',
    retailer: 'Retailer / Stockist Inquiry'
  };

  typeBtns.forEach(btn => {
    btn.addEventListener('click', () => {
      typeBtns.forEach(b => b.classList.remove('active'));
      btn.classList.add('active');
      contactSubject.value = subjectMap[btn.dataset.type];
    });
  });

  // Contact form submission
  const contactForm = document.getElementById('contactForm');
  const contactConfirmation = document.getElementById('contactConfirmation');

  if (contactForm) {
    contactForm.addEventListener('submit', function(e) {
      e.preventDefault();
      const submitBtn = contactForm.querySelector('.contact__submit');

      submitBtn.disabled = true;
      submitBtn.textContent = 'Sending...';

      const payload = Object.fromEntries(new FormData(contactForm));
      payload.subject = 'Kyn Skyn: ' + contactSubject.value;

      fetch('https://api.web3forms.com/submit', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json', 'Accept': 'application/json' },
        body: JSON.stringify(payload)
      })
      .then(res => res.json())
      .then(data => {
        if (data.success) {
          contactForm.reset();
          contactSubject.value = subjectMap.customer;
          typeBtns.forEach(b => b.classList.remove('active'));
          typeBtns[0].classList.add('active');
          submitBtn.textContent = 'Sent!';
          submitBtn.style.background = '#2a6e3f';
          contactConfirmation.style.display = 'block';
        } else {
          submitBtn.textContent = 'Try again';
          submitBtn.style.background = '#6e2a2a';
        }
        setTimeout(() => {
          submitBtn.textContent = 'Send Message';
          submitBtn.style.background = '';
          submitBtn.disabled = false;
        }, 4000);
      })
      .catch(() => {
        submitBtn.textContent = 'Try again';
        submitBtn.style.background = '#6e2a2a';
        setTimeout(() => {
          submitBtn.textContent = 'Send Message';
          submitBtn.style.background = '';
          submitBtn.disabled = false;
        }, 4000);
      });
    });
  }
</script>

{% schema %}
{
  "name": "Contact",
  "class": "contact-section"
}
{% endschema %}
