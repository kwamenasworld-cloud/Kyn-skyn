  <div class="notify__container fade-in">
    <p class="notify__eyebrow">Launching Soon</p>
    <h2 class="notify__heading">Be the first to know.</h2>
    <p class="notify__desc">Steady Serum drops Q3 2026. Sign up to stay informed, take part in product testing, or collaborate with us.</p>

    <iframe name="mc-hidden" style="display:none" aria-hidden="true"></iframe>
    <form class="notify__form" action="https://kynskyn.us15.list-manage.com/subscribe/post?u=61338503f23a719d2d581c864&id=051996d936" method="post" target="mc-hidden" novalidate>
      <input type="hidden" name="b_61338503f23a719d2d581c864_051996d936" value="">
      <input class="notify__input" type="email" name="EMAIL" placeholder="Email address" required>
      <button class="notify__button" type="submit">Notify Me</button>
    </form>
    <p id="formSuccess" style="display:none; color: var(--cream); opacity: 0.8; font-family: var(--font-sans); font-size: 0.9rem; margin-top: 1rem;">You're on the list. We'll be in touch.</p>

    <img src="{{ 'logomark-white.svg' | asset_url }}" alt="Kyn Skyn logomark" style="width: 4rem; height: auto; opacity: 0.15; margin-top: 3rem;">
  </div>
</section>

<script>
  (function() {
    var form = document.querySelector('.notify__form');
    if (!form) return;

    form.addEventListener('submit', function() {
      var btn = form.querySelector('.notify__button');
      var input = form.querySelector('.notify__input');
      var success = document.getElementById('formSuccess');

      btn.disabled = true;
      btn.textContent = 'Sending...';

      setTimeout(function() {
        btn.textContent = 'You\'re in!';
        btn.style.background = '#2a6e3f';
        input.value = '';
        if (success) success.style.display = 'block';
        setTimeout(function() {
          btn.textContent = 'Notify Me';
          btn.style.background = '';
          btn.disabled = false;
        }, 4000);
      }, 1500);
    });
  })();
</script>

