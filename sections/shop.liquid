      <a href="https://care.kynskyn.com/shop?utm_source=kynskyn&utm_medium=shop&utm_campaign=steady_serum" class="shop__featured-btn">Shop Now</a>
      <p class="shop__featured-note">No prescription needed. Free shipping on all orders.</p>
    </div>
  </div>

  <hr class="shop__divider">

  <!-- Prescription Treatment -->
  <div class="shop__section fade-in">
    <h2 class="shop__section-title">Prescription Treatment</h2>
    <p class="shop__section-desc" data-price="shop_treatment_desc">Included with Treatment Plan — $59.99/mo</p>
    <div class="shop__grid">

      <div class="shop__card">
        <div class="shop__card-img"><span>Ketoconazole</span><div class="shop__card-badge">Prescription</div></div>
        <div class="shop__card-body">
          <p class="shop__card-name">Ketoconazole 2% Cream</p>
          <p class="shop__card-desc">Antifungal cream for affected areas</p>
          <p class="shop__card-price">From $30/mo</p>
          <a href="https://care.kynskyn.com/book?utm_source=kynskyn&utm_medium=shop&utm_campaign=treatment_plan" class="shop__card-btn">Start Treatment Plan</a>
        </div>
      </div>

      <div class="shop__card">
        <div class="shop__card-img"><span>Fluconazole</span><div class="shop__card-badge">Prescription</div></div>
        <div class="shop__card-body">
          <p class="shop__card-name">Fluconazole 150mg</p>
          <p class="shop__card-desc">Oral antifungal — weekly dosing</p>
          <p class="shop__card-price">From $21/mo</p>
          <a href="https://care.kynskyn.com/book?utm_source=kynskyn&utm_medium=shop&utm_campaign=treatment_plan" class="shop__card-btn">Start Treatment Plan</a>
        </div>
      </div>

      <div class="shop__card">
        <div class="shop__card-img"><span>Tretinoin</span><div class="shop__card-badge">Prescription</div></div>
        <div class="shop__card-body">
          <p class="shop__card-name">Tretinoin Cream 0.02%</p>
          <p class="shop__card-desc">Retinoid cream for skin renewal</p>
          <p class="shop__card-price">From $30/mo</p>
          <a href="https://care.kynskyn.com/book?utm_source=kynskyn&utm_medium=shop&utm_campaign=treatment_plan" class="shop__card-btn">Start Treatment Plan</a>
        </div>
      </div>

      <div class="shop__card">
        <div class="shop__card-img"><span>Itraconazole</span><div class="shop__card-badge">Prescription</div></div>
        <div class="shop__card-body">
          <p class="shop__card-name">Itraconazole 100mg</p>
          <p class="shop__card-desc">Oral antifungal — daily dosing</p>
          <p class="shop__card-price">From $50/mo</p>
          <a href="https://care.kynskyn.com/book?utm_source=kynskyn&utm_medium=shop&utm_campaign=treatment_plan" class="shop__card-btn">Start Treatment Plan</a>
        </div>
      </div>

    </div>
    <p style="text-align: center; font-family: var(--font-sans); font-size: 0.75rem; color: var(--cream); opacity: 0.5; margin-top: 1.5rem;">
      Treatment Plan: $59.99/month or $149/quarter. Consultation + Rx. Add delivery + medication for $50/mo. Or $79 one-time consult.
    </p>
  </div>

</section>

<script>
  // Dynamic pricing from Supabase — single source of truth
  (function() {
    var SUPABASE_URL = 'https://pbriwsgraemyqhkymneq.supabase.co';
    var SUPABASE_KEY = 'eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9.eyJpc3MiOiJzdXBhYmFzZSIsInJlZiI6InBicml3c2dyYWVteXFoa3ltbmVxIiwicm9sZSI6ImFub24iLCJpYXQiOjE3NzUwNTQxNjEsImV4cCI6MjA5MDYzMDE2MX0.AFfCsWNblX3MzjOJVRL7JefLzaLQrsc6xHSeDZuFWrI';

    fetch(SUPABASE_URL + '/rest/v1/pricing_config?select=key,value', {
      headers: { 'apikey': SUPABASE_KEY }
    })
    .then(function(r) { return r.json(); })
    .then(function(prices) {
      var p = {};
      prices.forEach(function(row) { p[row.key] = Math.round(Number(row.value)); });

      var descEl = document.querySelector('[data-price="shop_treatment_desc"]');
      if (descEl && p.treatment_monthly) {
        var basePrice = p.treatment_monthly.toFixed ? p.treatment_monthly.toFixed(2).replace(/\.00$/, '') : p.treatment_monthly;
        descEl.textContent = 'Included with Treatment Plan — $' + basePrice + '/mo';
      }
    })
    .catch(function() { /* keep hardcoded defaults */ });
  })();
</script>

{% schema %}
{
  "name": "Shop",
  "class": "shop-page"
}
{% endschema %}
