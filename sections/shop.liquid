<style>
  /* Scoped to .shop-page so it doesn't leak into other templates */
  .shop-page {
    --amber: #F8B044;
    --amber-light: #fbc676;
    --terracotta: #C54427;
  }

  .shop-hero {
    position: relative;
    background: var(--maroon);
    color: var(--cream);
    padding: 4.5rem 1.5rem;
    overflow: hidden;
  }
  .shop-hero__watermark {
    position: absolute;
    inset: 0;
    background-image: url('{{ 'plus-grid.svg' | asset_url }}');
    background-repeat: no-repeat;
    background-position: right -180px top -100px;
    background-size: 620px 620px;
    opacity: 0.06;
    pointer-events: none;
  }
  .shop-hero__inner {
    position: relative;
    max-width: 1080px;
    margin: 0 auto;
  }
  .shop-hero__head {
    text-align: center;
    margin-bottom: 3rem;
  }
  .shop-hero__eyebrow {
    font-family: var(--font-sans);
    font-size: 0.7rem;
    text-transform: uppercase;
    letter-spacing: 0.3em;
    color: var(--amber);
    margin: 0 0 0.6rem 0;
  }
  .shop-hero__title {
    font-family: var(--font-accent);
    font-size: 3rem;
    line-height: 1.05;
    color: var(--cream);
    margin: 0 0 0.75rem 0;
  }
  .shop-hero__subtitle {
    font-family: var(--font-sans);
    font-size: 1rem;
    color: var(--cream);
    opacity: 0.85;
    max-width: 520px;
    margin: 0 auto;
    line-height: 1.6;
  }

  .shop-hero__featured {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 3rem;
    align-items: center;
    max-width: 900px;
    margin: 0 auto;
  }

  /* Amber-on-maroon package mockup — echoes the actual Steady Serum box */
  .shop-mockup {
    aspect-ratio: 1;
    position: relative;
    background: var(--maroon);
    border: 1px solid rgba(255, 244, 206, 0.15);
    border-radius: 20px;
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    gap: 0.8rem;
    overflow: hidden;
  }
  .shop-mockup__brand {
    position: absolute;
    top: 1.8rem;
    font-family: var(--font-sans);
    font-size: 0.65rem;
    text-transform: uppercase;
    letter-spacing: 0.3em;
    color: var(--amber);
    opacity: 0.75;
  }
  .shop-mockup__name {
    text-align: center;
    line-height: 0.95;
  }
  .shop-mockup__name-top {
    font-family: var(--font-accent);
    font-size: 4rem;
    color: var(--amber);
    margin: 0;
  }
  .shop-mockup__divider {
    height: 1px;
    width: 4rem;
    background: var(--amber);
    opacity: 0.4;
    margin: 0.8rem auto;
  }
  .shop-mockup__name-bottom {
    font-family: var(--font-accent);
    font-size: 2.6rem;
    color: var(--amber);
    opacity: 0.92;
    margin: 0;
  }
  .shop-mockup__size {
    position: absolute;
    bottom: 1.8rem;
    font-family: var(--font-sans);
    font-size: 0.65rem;
    text-transform: uppercase;
    letter-spacing: 0.3em;
    color: var(--cream);
    opacity: 0.5;
  }

  .shop-featured__cta-wrap {
    position: relative;
    display: inline-block;
  }

  .shop-featured__sticker {
    position: absolute;
    top: -14px;
    left: -14px;
    transform: rotate(-8deg);
    transform-origin: center;
    z-index: 3;
    display: inline-block;
    background: var(--dark);
    color: var(--cream);
    border: 1.5px solid rgba(255, 244, 206, 0.45);
    border-radius: 2rem;
    font-family: var(--font-accent);
    font-size: 0.72rem;
    letter-spacing: 0.14em;
    text-transform: uppercase;
    padding: 0.5rem 1.1rem;
    box-shadow: 0 8px 22px -8px rgba(42, 2, 8, 0.7);
    pointer-events: none;
    white-space: nowrap;
    animation: shopStickerPop 0.6s cubic-bezier(0.34, 1.56, 0.64, 1) 0.3s both,
               shopStickerWiggle 6s ease-in-out 2s infinite;
  }

  @keyframes shopStickerPop {
    from { opacity: 0; transform: rotate(-22deg) scale(0.7); }
    to   { opacity: 1; transform: rotate(-8deg) scale(1); }
  }

  @keyframes shopStickerWiggle {
    0%, 100% { transform: rotate(-8deg) translateY(0); }
    50%      { transform: rotate(-6deg) translateY(-2px); }
  }

  @media (prefers-reduced-motion: reduce) {
    .shop-featured__sticker { animation: none; transform: rotate(-8deg); }
  }

  /* Product image — replaces the mockup when a featured product is set */
  .shop-featured__image {
    aspect-ratio: 1;
    background: var(--maroon);
    border: 1px solid rgba(255, 244, 206, 0.15);
    border-radius: 20px;
    overflow: hidden;
    display: flex;
    align-items: center;
    justify-content: center;
  }
  .shop-featured__image img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
  }

  .shop-featured__info { }
  .shop-featured__label {
    font-family: var(--font-sans);
    font-size: 0.7rem;
    text-transform: uppercase;
    letter-spacing: 0.25em;
    color: var(--amber);
    margin: 0 0 0.5rem 0;
  }
  .shop-featured__name {
    font-family: var(--font-accent);
    font-size: 2.6rem;
    color: var(--cream);
    line-height: 1.05;
    margin: 0 0 0.8rem 0;
  }
  .shop-featured__price {
    font-family: var(--font-accent);
    font-size: 1.75rem;
    color: var(--amber);
    margin: 0 0 1.25rem 0;
  }
  .shop-featured__desc {
    font-family: var(--font-sans);
    font-size: 1rem;
    color: var(--cream);
    opacity: 0.92;
    line-height: 1.7;
    margin: 0 0 1.5rem 0;
  }
  .shop-featured__desc p { margin: 0 0 0.85rem 0; }
  .shop-featured__desc p:last-child { margin-bottom: 0; }
  .shop-featured__btn {
    display: inline-block;
    font-family: var(--font-sans);
    font-size: 1rem;
    font-weight: 500;
    background: var(--amber);
    color: var(--maroon);
    border: none;
    padding: 0.9rem 2.5rem;
    border-radius: 10px;
    cursor: pointer;
    text-decoration: none;
    transition: background 0.2s;
  }
  .shop-featured__btn:hover { background: var(--amber-light); }
  .shop-featured__note {
    font-family: var(--font-sans);
    font-size: 0.75rem;
    color: var(--cream);
    opacity: 0.7;
    margin: 0.85rem 0 0 0;
  }

  /* Values strip — cream section, high contrast */
  .shop-values {
    background: var(--cream);
    color: var(--maroon);
    padding: 3.5rem 1.5rem;
  }
  .shop-values__grid {
    max-width: 900px;
    margin: 0 auto;
    display: grid;
    grid-template-columns: 1fr 1fr 1fr;
    gap: 2.5rem;
  }
  .shop-values__item {
    text-align: center;
  }
  .shop-values__icon {
    width: 3rem;
    height: 3rem;
    margin: 0 auto 0.75rem;
    border-radius: 14px;
    background: rgba(5, 90, 91, 0.1);
    color: #055A5B;
    display: flex;
    align-items: center;
    justify-content: center;
  }
  .shop-values__title {
    font-family: var(--font-serif);
    font-size: 1.05rem;
    color: var(--maroon);
    margin: 0 0 0.35rem 0;
  }
  .shop-values__desc {
    font-family: var(--font-sans);
    font-size: 0.8rem;
    color: var(--maroon);
    opacity: 0.7;
    line-height: 1.55;
    margin: 0;
  }

  @media (max-width: 640px) {
    .shop-hero { padding: 3rem 1.25rem; }
    .shop-hero__title { font-size: 2rem; }
    .shop-hero__featured { grid-template-columns: 1fr; gap: 2rem; }
    .shop-mockup__name-top { font-size: 3rem; }
    .shop-mockup__name-bottom { font-size: 2rem; }
    .shop-featured__name { font-size: 2rem; }
    .shop-featured__cta-wrap { display: block; }
    .shop-featured__btn { width: 100%; text-align: center; }
    .shop-values__grid { grid-template-columns: 1fr; gap: 1.75rem; }
  }
</style>

<section class="shop-hero">
  <div class="shop-hero__watermark" aria-hidden="true"></div>
  <div class="shop-hero__inner">
    <div class="shop-hero__head fade-in">
      <p class="shop-hero__eyebrow">Kyn Skyn Cosmetics</p>
      <h1 class="shop-hero__title">Shop</h1>
      <p class="shop-hero__subtitle">Malassezia-safe skincare for fungal-prone skin. No prescription needed.</p>
    </div>

    {%- assign featured_product = section.settings.product -%}
    {%- if featured_product != blank -%}
      {%- assign featured_variant = featured_product.selected_or_first_available_variant -%}
    {%- endif -%}
    <div class="shop-hero__featured fade-in">
      <div class="shop-featured__media">
        {%- if featured_product != blank and featured_product.featured_image != blank -%}
          <div class="shop-featured__image">
            <img
              src="{{ featured_product.featured_image | image_url: width: 800 }}"
              alt="{{ featured_product.featured_image.alt | default: featured_product.title | escape }}"
              width="{{ featured_product.featured_image.width }}"
              height="{{ featured_product.featured_image.height }}"
              loading="lazy">
          </div>
        {%- else -%}
          <div class="shop-mockup" aria-hidden="true">
            <span class="shop-mockup__brand">Kyn Skyn</span>
            <div class="shop-mockup__name">
              <p class="shop-mockup__name-top">STEADY</p>
              <div class="shop-mockup__divider"></div>
              <p class="shop-mockup__name-bottom">SERUM</p>
            </div>
            <span class="shop-mockup__size">30 ml</span>
          </div>
        {%- endif -%}
      </div>
      <div class="shop-featured__info">
        <p class="shop-featured__label">{% if featured_product != blank and featured_product.type != blank %}{{ featured_product.type }}{% else %}Serum{% endif %}</p>
        <h2 class="shop-featured__name">{% if featured_product != blank %}{{ featured_product.title }}{% else %}Steady Serum{% endif %}</h2>
        <p class="shop-featured__price">{% if featured_variant != blank %}{{ featured_variant.price | money_without_trailing_zeros }}{% else %}$38{% endif %}</p>
        <div class="shop-featured__desc">{% if featured_product != blank and featured_product.description != blank %}{{ featured_product.description }}{% else %}<p>Steady Serum hydrates with lightweight MCT oil, which Malassezia yeast can't digest. Coconut, olive, and most plant oils make fungal acne worse. MCT is one of the few exceptions, and it absorbs fast without a greasy finish.</p>{% endif %}</div>
        <div class="shop-featured__cta-wrap">
          {%- unless featured_variant != blank and featured_variant.available -%}
            <span class="shop-featured__sticker" aria-hidden="true">Coming Soon</span>
          {%- endunless -%}
          {%- if featured_product != blank -%}
            <form action="{{ routes.cart_add_url }}" method="post" enctype="multipart/form-data" class="shop-featured__form">
              <input type="hidden" name="id" value="{{ featured_variant.id }}">
              <input type="hidden" name="quantity" value="1">
              <button type="submit" class="shop-featured__btn"{% unless featured_variant.available %} disabled{% endunless %}>
                {%- if featured_variant.available -%}Add to Cart — {{ featured_variant.price | money_without_trailing_zeros }}{%- else -%}Sold out{%- endif -%}
              </button>
            </form>
          {%- else -%}
            <a href="/products/steady-serum" class="shop-featured__btn">Add to Cart — $38</a>
          {%- endif -%}
        </div>
        <p class="shop-featured__note">Free shipping on every order.</p>
      </div>
    </div>
  </div>
</section>

<section class="shop-values">
  <div class="shop-values__grid">
    <div class="shop-values__item fade-in">
      <div class="shop-values__icon">
        <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
          <path d="M9 12.75 11.25 15 15 9.75m-3-7.036A11.959 11.959 0 0 1 3.598 6 11.99 11.99 0 0 0 3 9.749c0 5.592 3.824 10.29 9 11.623 5.176-1.332 9-6.03 9-11.623 0-1.31-.21-2.571-.598-3.751h-.152c-3.196 0-6.1-1.248-8.25-3.285Z"/>
        </svg>
      </div>
      <h3 class="shop-values__title">Malassezia-safe</h3>
      <p class="shop-values__desc">No oils, esters, or fatty acids that feed fungal yeast.</p>
    </div>
    <div class="shop-values__item fade-in">
      <div class="shop-values__icon">
        <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
          <path d="M8.25 18.75a1.5 1.5 0 0 1-3 0m3 0a1.5 1.5 0 0 0-3 0m3 0h6m-9 0H3.375a1.125 1.125 0 0 1-1.125-1.125V14.25m17.25 4.5a1.5 1.5 0 0 1-3 0m3 0a1.5 1.5 0 0 0-3 0m3 0h1.125c.621 0 1.129-.504 1.09-1.124a17.902 17.902 0 0 0-3.213-9.193 2.056 2.056 0 0 0-1.58-.86H14.25"/>
        </svg>
      </div>
      <h3 class="shop-values__title">Free shipping</h3>
      <p class="shop-values__desc">On every order, no minimum.</p>
    </div>
    <div class="shop-values__item fade-in">
      <div class="shop-values__icon">
        <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
          <path d="M16.5 10.5V6.75a4.5 4.5 0 1 0-9 0v3.75m-.75 11.25h10.5a2.25 2.25 0 0 0 2.25-2.25v-6.75a2.25 2.25 0 0 0-2.25-2.25H6.75a2.25 2.25 0 0 0-2.25 2.25v6.75a2.25 2.25 0 0 0 2.25 2.25Z"/>
        </svg>
      </div>
      <h3 class="shop-values__title">No prescription</h3>
      <p class="shop-values__desc">Over the counter. Skip the derm visit.</p>
    </div>
  </div>
</section>

{% schema %}
{
  "name": "Shop",
  "class": "shop-page",
  "settings": [
    {
      "type": "product",
      "id": "product",
      "label": "Featured product",
      "info": "When set, the Add to Cart button posts to the Shopify cart instead of redirecting to care.kynskyn.com."
    }
  ]
}
{% endschema %}
