<script>
  (function() {
    var pricingCta = document.getElementById('thPricingCta');
    var plans = document.querySelectorAll('.th-plan');
    var augmentInput = document.querySelector('.th-plan__augment-input[data-augment="quarterly"]');
    var CTA_LABELS = {
      'monthly': 'Continue with Monthly · $[price]/mo',
      'bimonthly': 'Continue every 2 months · $[price]/2mo',
      'quarterly': 'Continue with Quarterly · $[price]/qtr',
      'one-time': 'Book One-time Consult · $[price]'
    };

    function readPrice(selector) {
      var el = document.querySelector(selector);
      if (!el) return '';
      var clone = el.cloneNode(true);
      var suffix = clone.querySelector('.th-plan__price-suffix');
      if (suffix) suffix.parentNode.removeChild(suffix);
      return clone.textContent.replace(/[^0-9.]/g, '');
    }

    // Determine effective plan: selected card, overridden to quarterly if Monthly + augment checkbox
    function getEffectivePlan() {
      var selected = document.querySelector('.th-plan.th-plan--selected');
      var plan = selected ? selected.getAttribute('data-plan') : 'monthly';
      if (plan === 'monthly' && augmentInput && augmentInput.checked) return 'quarterly';
      return plan;
    }

    function setPricingCta() {
      // No-op while the page is in pre-launch waitlist mode.
      // The CTA stays as a static scroll link to #th-waitlist.
    }

    plans.forEach(function(plan) {
      plan.addEventListener('click', function(e) {
        // Don't hijack clicks inside the augment toggle label
        if (e.target && e.target.closest && e.target.closest('.th-plan__augment')) return;
        plans.forEach(function(p) {
          p.classList.remove('th-plan--selected');
          p.setAttribute('aria-checked', 'false');
        });
        plan.classList.add('th-plan--selected');
        plan.setAttribute('aria-checked', 'true');
        // Switching to a non-Monthly card clears the quarterly augment
        if (augmentInput && plan.getAttribute('data-plan') !== 'monthly') {
          augmentInput.checked = false;
        }
        setPricingCta();
      });
    });

    if (augmentInput) {
      augmentInput.addEventListener('change', function() {
        // Turning on the augment forces the Monthly card to be selected
        if (augmentInput.checked) {
          plans.forEach(function(p) {
            var isMonthly = p.getAttribute('data-plan') === 'monthly';
            p.classList.toggle('th-plan--selected', isMonthly);
            p.setAttribute('aria-checked', isMonthly ? 'true' : 'false');
          });
        }
        setPricingCta();
      });
    }
  })();

  // ── Waitlist form submission ──
  (function () {
    var form = document.getElementById('thWaitlistForm');
    if (!form) return;
    var input = form.querySelector('input[type="email"]');
    var btn = form.querySelector('.th-waitlist__button');
    var note = document.getElementById('thWaitlistNote');

    form.addEventListener('submit', async function (e) {
      e.preventDefault();
      var email = input.value.trim();
      if (!email) return;

      btn.disabled = true;
      btn.textContent = 'Joining...';
      note.textContent = '';

      try {
        var formData = new FormData();
        formData.append('form_type', 'customer');
        formData.append('utf8', '\u2713');
        formData.append('contact[email]', email);
        formData.append('contact[tags]', 'telehealth-waitlist,consultation-page,offer-20-off-quarterly');

        await fetch('https://kynskyn.com/contact#contact_form', {
          method: 'POST',
          body: formData,
          mode: 'no-cors'
        });

        btn.textContent = "You're on the list";
        btn.style.background = '#2a6e3f';
        btn.style.borderColor = '#2a6e3f';
        btn.style.color = '#ffffff';
        note.textContent = "We'll email you on July 1 with your $20-off code.";
        note.style.color = '#C5FEFF';
      } catch (err) {
        btn.disabled = false;
        btn.textContent = 'Join the waitlist';
        note.textContent = 'Something went wrong — please try again.';
        note.style.color = '#e8725a';
      }
    });
  })();
</script>


<!-- ====== WAITLIST ====== -->
<section class="th-cta" id="th-waitlist">
  <div class="th-cta__container fade-in">
    <p class="th-waitlist__eyebrow">Opening July 1, 2026</p>
    <h2 class="th-cta__heading">Be first in line.</h2>
    <p class="th-cta__desc">Join the Kyn Skyn Rx waitlist and we'll email you the moment booking opens. Waitlist members get <strong>$20 off their first quarterly plan</strong> — $149 becomes $129, and that includes provider consultation plus Rx sent to your pharmacy.</p>
    <form class="th-waitlist__form" id="thWaitlistForm">
      <input type="email" class="th-waitlist__input" placeholder="you@email.com" required aria-label="Email address">
      <button type="submit" class="th-waitlist__button">Join the waitlist</button>
    </form>
    <p class="th-waitlist__note" id="thWaitlistNote"></p>
    <p class="th-cta__note">One email when we launch. No spam. Unsubscribe anytime.</p>
  </div>
</section>

<!-- ====== FAQ ====== -->
<section class="th-faq">
  <div class="th-faq__container">
    <h2 class="th-faq__heading fade-in">Common questions</h2>

    <div class="th-faq__item fade-in">
      <button class="th-faq__q" type="button">What conditions can I get diagnosed for?</button>
      <div class="th-faq__a">Our providers focus on Malassezia-related skin conditions: fungal acne (Malassezia folliculitis), seborrheic dermatitis, and tinea versicolor. They all trace back to the same yeast overgrowth, which is why generic acne or eczema treatments tend to miss.</div>
    </div>

    <div class="th-faq__item fade-in">
      <button class="th-faq__q" type="button">How does the consultation work?</button>
      <div class="th-faq__a">You meet a licensed provider (MD, DO, or NP) over video. Before the visit you fill out intake and upload photos of your skin. During the call, your provider goes through your history and photos with you, then gives you the diagnosis and plan.</div>
    </div>

    <div class="th-faq__item fade-in">
      <button class="th-faq__q" type="button">Can I get a prescription?</button>
      <div class="th-faq__a">Yes. If your provider decides a prescription is the right call, they e-prescribe it straight to your pharmacy. That typically means a topical or oral antifungal, depending on what you have.</div>
    </div>

    <div class="th-faq__item fade-in">
      <button class="th-faq__q" type="button">Is this covered by insurance?</button>
      <div class="th-faq__a">It depends on your plan. A lot of insurers do cover virtual dermatology visits, but some don't — call yours before you book. We'll hand you an itemized receipt so you can file a claim yourself.</div>
    </div>

    <div class="th-faq__item fade-in">
      <button class="th-faq__q" type="button">How is my health information protected?</button>
      <div class="th-faq__a">All consultations run on a HIPAA-compliant platform. Your medical records are encrypted at rest and in transit, and we don't share them with third parties. We also keep the care platform entirely separate from the shop — your clinical data never sits next to your order history.</div>
    </div>

    <div class="th-faq__item fade-in">
      <button class="th-faq__q" type="button">I already used the Ingredient Checker. Should I still book?</button>
      <div class="th-faq__a">The Ingredient Checker flags products that may be feeding Malassezia, but it can't diagnose you. A provider can tell you whether it's actually fungal acne, seb derm, or tinea versicolor — and can prescribe the antifungals you can't buy over the counter.</div>
    </div>

    <div class="th-faq__item fade-in">
      <button class="th-faq__q" type="button">How much does a consultation cost?</button>
      <div class="th-faq__a" data-price="faq_pricing">Treatment Plans are $59.99/month, $69.99 every 2 months, or $149 quarterly. All include your provider consultation and prescription sent to your pharmacy. A one-time consult is $79. Optional medication and home delivery add-on is $50/month. Payment runs securely through Stripe.</div>
    </div>

    <div class="th-faq__item fade-in">
      <button class="th-faq__q" type="button">Do I need to upload photos of my skin?</button>
      <div class="th-faq__a">Photos are optional, but please upload them if you can — it makes a real difference at the visit. You can attach up to 5 when you book. We strip GPS and device metadata before storing them, and only your treating provider can see them.</div>
    </div>

    <div class="th-faq__item fade-in">
      <button class="th-faq__q" type="button">How do I select a pharmacy?</button>
      <div class="th-faq__a">During booking, you search for pharmacies by name and ZIP code. If your provider prescribes anything, the e-prescription is sent to whichever pharmacy you picked.</div>
    </div>

    <div class="th-faq__item fade-in">
      <button class="th-faq__q" type="button">What payment methods do you accept?</button>
      <div class="th-faq__a">All payments run through Stripe. We take major credit and debit cards (Visa, Mastercard, Amex, Discover), plus Apple Pay and Google Pay.</div>
    </div>
  </div>
</section>

<script>
