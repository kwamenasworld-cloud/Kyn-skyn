      }
      var otEl = document.querySelector('[data-price="treatment_onetime"]');
      if (otEl && p.treatment_onetime) {
        otEl.textContent = '$' + p.treatment_onetime;
      }

      // Update FAQ pricing text
      var faqEl = document.querySelector('[data-price="faq_pricing"]');
      if (faqEl && p.treatment_monthly && p.treatment_onetime && p.treatment_quarterly && p.treatment_bimonthly && p.delivery_addon_monthly) {
        faqEl.textContent = 'Treatment Plans are $' + p.treatment_monthly + '/month, $' + p.treatment_bimonthly + ' every 2 months, or $' + p.treatment_quarterly + ' quarterly — all include your provider consultation and prescription sent to your pharmacy. A one-time consult is available for $' + p.treatment_onetime + '. Optional delivery + medication add-on is $' + p.delivery_addon_monthly + '/month. Payment is processed securely through Stripe.';
      }
    })
    .catch(function() { /* keep hardcoded defaults */ });
  })();
</script>

