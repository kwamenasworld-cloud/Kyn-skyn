{% comment %}
  Press page. Lives at /pages/press. Designed to make journalist outreach easy:
  founder bio, brand stats, downloadable logos, story angles, and a contact.
{% endcomment %}

<style>
  /* ====== HERO ====== */
  .press-hero {
    background: var(--cream);
    padding: 9rem 3rem 4rem;
    text-align: center;
  }

  .press-hero__eyebrow {
    font-family: var(--font-accent);
    font-size: 0.75rem;
    letter-spacing: 0.18em;
    text-transform: uppercase;
    color: var(--maroon);
    opacity: 0.55;
    margin-bottom: 1.2rem;
  }

  .press-hero__heading {
    font-family: var(--font-serif);
    font-size: clamp(2.4rem, 5vw, 4rem);
    font-weight: 300;
    color: var(--maroon);
    line-height: 1.1;
    margin-bottom: 1.5rem;
  }

  .press-hero__sub {
    font-family: var(--font-sans);
    font-size: clamp(1rem, 1.6vw, 1.15rem);
    line-height: 1.7;
    color: var(--maroon);
    opacity: 0.7;
    max-width: 38rem;
    margin: 0 auto;
  }

  /* ====== FAST FACTS ====== */
  .press-facts {
    background: var(--cream);
    padding: 3rem 3rem 4rem;
  }

  .press-facts__container {
    max-width: 60rem;
    margin: 0 auto;
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: 1rem;
  }

  .press-facts__card {
    background: rgba(100, 18, 32, 0.04);
    border: 1px solid rgba(100, 18, 32, 0.1);
    border-radius: 8px;
    padding: 1.5rem 1.25rem;
  }

  .press-facts__label {
    font-family: var(--font-accent);
    font-size: 0.62rem;
    letter-spacing: 0.16em;
    text-transform: uppercase;
    color: var(--maroon);
    opacity: 0.55;
    margin-bottom: 0.6rem;
  }

  .press-facts__value {
    font-family: var(--font-serif);
    font-size: 1.1rem;
    font-weight: 400;
    color: var(--maroon);
    line-height: 1.3;
  }

  /* ====== POSITIONING ====== */
  .press-position {
    background: var(--dark);
    color: var(--cream);
    padding: 6rem 3rem;
  }

  .press-position__container { max-width: 44rem; margin: 0 auto; }

  .press-position__label {
    font-family: var(--font-accent);
    font-size: 0.7rem;
    letter-spacing: 0.18em;
    text-transform: uppercase;
    opacity: 0.5;
    margin-bottom: 1.5rem;
  }

  .press-position__heading {
    font-family: var(--font-serif);
    font-size: clamp(1.8rem, 3.2vw, 2.6rem);
    font-weight: 400;
    line-height: 1.2;
    margin-bottom: 1.5rem;
  }

  .press-position__body {
    font-family: var(--font-sans);
    font-size: 1rem;
    line-height: 1.8;
    opacity: 0.75;
  }

  .press-position__body p + p { margin-top: 1.2rem; }

  /* ====== STORY ANGLES ====== */
  .press-angles {
    background: var(--cream);
    padding: 6rem 3rem;
  }

  .press-angles__container { max-width: 56rem; margin: 0 auto; }

  .press-angles__heading {
    font-family: var(--font-serif);
    font-size: clamp(2rem, 3.5vw, 2.6rem);
    font-weight: 400;
    color: var(--maroon);
    margin-bottom: 0.6rem;
  }

  .press-angles__sub {
    font-family: var(--font-sans);
    font-size: 0.95rem;
    color: var(--maroon);
    opacity: 0.65;
    margin-bottom: 3rem;
  }

  .press-angles__list {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 1.5rem;
  }

  .press-angles__card {
    background: rgba(100, 18, 32, 0.04);
    border: 1px solid rgba(100, 18, 32, 0.1);
    border-radius: 8px;
    padding: 1.75rem;
  }

  .press-angles__num {
    font-family: var(--font-accent);
    font-size: 0.65rem;
    letter-spacing: 0.18em;
    text-transform: uppercase;
    color: var(--terracotta);
    margin-bottom: 0.8rem;
  }

  .press-angles__title {
    font-family: var(--font-serif);
    font-size: 1.2rem;
    font-weight: 500;
    color: var(--maroon);
    line-height: 1.3;
    margin-bottom: 0.7rem;
  }

  .press-angles__body {
    font-family: var(--font-sans);
    font-size: 0.9rem;
    line-height: 1.65;
    color: var(--maroon);
    opacity: 0.75;
  }

  /* ====== ASSETS ====== */
  .press-assets {
    background: var(--dark);
    color: var(--cream);
    padding: 6rem 3rem;
  }

  .press-assets__container { max-width: 56rem; margin: 0 auto; }

  .press-assets__heading {
    font-family: var(--font-serif);
    font-size: clamp(2rem, 3.5vw, 2.6rem);
    font-weight: 400;
    margin-bottom: 0.6rem;
  }

  .press-assets__sub {
    font-family: var(--font-sans);
    font-size: 0.95rem;
    opacity: 0.6;
    margin-bottom: 3rem;
  }

  .press-assets__grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 1rem;
  }

  .press-assets__item {
    border: 1px solid rgba(255, 244, 206, 0.12);
    border-radius: 8px;
    padding: 1.4rem;
    text-decoration: none;
    color: var(--cream);
    transition: border-color 0.3s, background 0.3s;
    display: block;
  }

  .press-assets__item:hover {
    border-color: rgba(255, 244, 206, 0.3);
    background: rgba(255, 244, 206, 0.03);
  }

  .press-assets__item-label {
    font-family: var(--font-accent);
    font-size: 0.62rem;
    letter-spacing: 0.16em;
    text-transform: uppercase;
    opacity: 0.5;
    margin-bottom: 0.55rem;
  }

  .press-assets__item-title {
    font-family: var(--font-serif);
    font-size: 1rem;
    font-weight: 400;
    margin-bottom: 0.4rem;
  }

  .press-assets__item-meta {
    font-family: var(--font-sans);
    font-size: 0.75rem;
    opacity: 0.5;
  }

  /* ====== CONTACT ====== */
  .press-contact {
    background: var(--cream);
    padding: 6rem 3rem;
    text-align: center;
  }

  .press-contact__container { max-width: 36rem; margin: 0 auto; }

  .press-contact__eyebrow {
    font-family: var(--font-accent);
    font-size: 0.7rem;
    letter-spacing: 0.18em;
    text-transform: uppercase;
    color: var(--maroon);
    opacity: 0.55;
    margin-bottom: 1.2rem;
  }

  .press-contact__heading {
    font-family: var(--font-serif);
    font-size: clamp(1.8rem, 3.2vw, 2.4rem);
    font-weight: 400;
    color: var(--maroon);
    line-height: 1.2;
    margin-bottom: 1.5rem;
  }

  .press-contact__email {
    display: inline-block;
    font-family: var(--font-sans);
    font-size: 1.1rem;
    color: var(--maroon);
    text-decoration: none;
    border-bottom: 1px solid rgba(100, 18, 32, 0.4);
    padding-bottom: 0.2rem;
    transition: border-color 0.3s;
  }

  .press-contact__email:hover { border-color: var(--maroon); }

  .press-contact__note {
    font-family: var(--font-sans);
    font-size: 0.85rem;
    color: var(--maroon);
    opacity: 0.55;
    margin-top: 2rem;
    line-height: 1.6;
  }

  /* ====== RESPONSIVE ====== */
  @media (max-width: 768px) {
    .press-hero { padding: 7rem 1.5rem 3rem; }
    .press-facts { padding: 2rem 1.5rem 3rem; }
    .press-facts__container { grid-template-columns: repeat(2, 1fr); }
    .press-position { padding: 4rem 1.5rem; }
    .press-angles { padding: 4rem 1.5rem; }
    .press-angles__list { grid-template-columns: 1fr; }
    .press-assets { padding: 4rem 1.5rem; }
    .press-assets__grid { grid-template-columns: 1fr; }
    .press-contact { padding: 4rem 1.5rem; }
  }
</style>

<section class="press-hero">
  <p class="press-hero__eyebrow">Press</p>
  <h1 class="press-hero__heading">Kyn Skyn at a glance.</h1>
  <p class="press-hero__sub">A brand and telehealth platform built for one of dermatology's most misdiagnosed conditions. Founder available for interviews. Assets, story angles, and contact below.</p>
</section>

<section class="press-facts">
  <div class="press-facts__container">
    <div class="press-facts__card">
      <p class="press-facts__label">Founded</p>
      <p class="press-facts__value">2026</p>
    </div>
    <div class="press-facts__card">
      <p class="press-facts__label">Category</p>
      <p class="press-facts__value">Skincare and telehealth</p>
    </div>
    <div class="press-facts__card">
      <p class="press-facts__label">Specialty</p>
      <p class="press-facts__value">Fungus-prone skin</p>
    </div>
    <div class="press-facts__card">
      <p class="press-facts__label">Launch</p>
      <p class="press-facts__value">June 1, 2026</p>
    </div>
  </div>
</section>

<section class="press-position">
  <div class="press-position__container">
    <p class="press-position__label">The position</p>
    <h2 class="press-position__heading">The first vertically integrated skincare and telehealth platform built specifically for fungal acne, seborrheic dermatitis, and Malassezia-related skin conditions.</h2>
    <div class="press-position__body">
      <p>Roughly one in three patients walking into a dermatologist's office for "acne that won't clear" actually has a different condition. Many have <em>Malassezia folliculitis</em>, a yeast-driven look-alike that does not respond to standard acne treatments and is often made worse by them. The wider category, fungus-prone skin, includes seborrheic dermatitis, dandruff, and tinea versicolor. Together these conditions affect tens of millions of people in the United States alone.</p>
      <p>The skincare industry has largely ignored this category. Mainstream brands formulate with ingredients that feed <em>Malassezia</em>. Generic telehealth platforms prescribe acne meds that miss the diagnosis. Kyn Skyn was built to fix both ends: malassezia-safe formulas at one end, real clinician-led care with prescription-strength antifungals at the other.</p>
      <p>The visual language and clinical literacy are deliberately built around darker skin tones, where these conditions present differently and where the industry has historically lagged.</p>
    </div>
  </div>
</section>

<section class="press-angles">
  <div class="press-angles__container">
    <h2 class="press-angles__heading">Story angles</h2>
    <p class="press-angles__sub">Written for journalists. Each one is a real story Kyn Skyn can speak to with data, patient cases, or expert sources.</p>

    <div class="press-angles__list">
      <article class="press-angles__card">
        <p class="press-angles__num">Angle 01</p>
        <h3 class="press-angles__title">The acne that isn't acne.</h3>
        <p class="press-angles__body">Why fungal acne goes undiagnosed for years, why standard acne treatments make it worse, and why a category of skincare that addresses it has only recently begun to exist.</p>
      </article>

      <article class="press-angles__card">
        <p class="press-angles__num">Angle 02</p>
        <h3 class="press-angles__title">Telehealth for the conditions Curology cannot solve.</h3>
        <p class="press-angles__body">Generic telehealth dermatology platforms work well for adult acne and rosacea. They struggle with the conditions that need a specialist's eye and a different prescription pad. A specialty model is emerging.</p>
      </article>

      <article class="press-angles__card">
        <p class="press-angles__num">Angle 03</p>
        <h3 class="press-angles__title">The dermatology blind spot for darker skin.</h3>
        <p class="press-angles__body">Seborrheic dermatitis and tinea versicolor present differently on melanin-rich skin and are routinely missed or mistreated. A founder building from inside that experience.</p>
      </article>

      <article class="press-angles__card">
        <p class="press-angles__num">Angle 04</p>
        <h3 class="press-angles__title">Inside the founder's skin journey.</h3>
        <p class="press-angles__body">A first-person story of years of misdiagnosis, the science that finally explained it, and the decision to build a brand around the condition rather than around it.</p>
      </article>
    </div>
  </div>
</section>

<section class="press-assets">
