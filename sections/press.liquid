    <p class="press-assets__sub">Logos, founder photo, and supporting links. Use freely in coverage about Kyn Skyn.</p>

    <div class="press-assets__grid">
      <a href="{{ 'logomark.svg' | asset_url }}" class="press-assets__item" download>
        <p class="press-assets__item-label">Logo</p>
        <p class="press-assets__item-title">Logomark</p>
        <p class="press-assets__item-meta">SVG &middot; vector</p>
      </a>

      <a href="{{ 'logoword-white.png' | asset_url }}" class="press-assets__item" download>
        <p class="press-assets__item-label">Logo</p>
        <p class="press-assets__item-title">Wordmark, light</p>
        <p class="press-assets__item-meta">PNG &middot; for dark backgrounds</p>
      </a>

      <a href="{{ 'logomark-white.png' | asset_url }}" class="press-assets__item" download>
        <p class="press-assets__item-label">Logo</p>
        <p class="press-assets__item-title">Logomark, light</p>
        <p class="press-assets__item-meta">PNG &middot; for dark backgrounds</p>
      </a>

      <a href="{{ 'chandani-closeup.jpg' | asset_url }}" class="press-assets__item" download>
        <p class="press-assets__item-label">Photo</p>
        <p class="press-assets__item-title">Hero photography</p>
        <p class="press-assets__item-meta">JPG &middot; high-res</p>
      </a>

      <a href="/pages/fungal-acne" class="press-assets__item">
        <p class="press-assets__item-label">Editorial</p>
        <p class="press-assets__item-title">Fungal acne explainer</p>
        <p class="press-assets__item-meta">Web &middot; cite-able</p>
      </a>

      <a href="/pages/handbook" class="press-assets__item">
        <p class="press-assets__item-label">Editorial</p>
        <p class="press-assets__item-title">Skin handbook</p>
        <p class="press-assets__item-meta">Web &middot; conditions overview</p>
      </a>
    </div>
  </div>
</section>

<section class="press-contact">
  <div class="press-contact__container">
    <p class="press-contact__eyebrow">Press inquiries</p>
    <h2 class="press-contact__heading">Reach the founder directly.</h2>
    <a href="mailto:press@kynskyn.com" class="press-contact__email">press@kynskyn.com</a>
    <p class="press-contact__note">For interviews, expert quotes on fungal acne and Malassezia-related conditions, or product samples, email the address above. Response within 48 hours. You can also use the <a href="/pages/contact-1" style="color: var(--maroon); text-decoration: underline;">contact form</a> if you prefer.</p>
  </div>
</section>

{% schema %}
{
  "name": "Press",
  "class": "press-section"
}
{% endschema %}
