<script>
  // ── Treatment card expand/collapse ──
  document.querySelectorAll('.treatment-header').forEach(header => {
    header.addEventListener('click', () => {
      const card = header.closest('.treatment-card');
      card.classList.toggle('expanded');
    });
  });

  // ── Background decorations ──
  (() => {
    const container = document.getElementById('bgDecor');
    const pageH = document.documentElement.scrollHeight;
    // Size the absolute container to full page
    container.style.height = pageH + 'px';

    const colors = [
      { stroke: '100,18,32',  fill: '100,18,32' },   // burgundy
      { stroke: '197,68,39',  fill: '197,68,39' },    // burnt-red
      { stroke: '248,176,68', fill: '248,176,68' },   // gold
      { stroke: '5,85,40',    fill: '5,85,40' },      // deep-green
      { stroke: '5,90,91',    fill: '5,90,91' },      // teal
      { stroke: '31,63,111',  fill: '31,63,111' },    // navy
    ];

    const shapes = {
      cell(sz, c) {
        const r = sz / 2 - 4;
        return `<circle cx="${sz/2}" cy="${sz/2}" r="${r}" fill="rgba(${c.fill},0.08)" stroke="rgba(${c.stroke},0.14)" stroke-width="1.5"/>
                <circle cx="${sz/2}" cy="${sz/2}" r="${r*0.55}" fill="none" stroke="rgba(${c.stroke},0.10)" stroke-width="1" stroke-dasharray="4 6"/>`;
      },
      molecule(sz, c) {
        const cx = sz/2, cy = sz/2, r = sz*0.16;
        const pts = [[cx, cy-sz*0.22], [cx-sz*0.2, cy+sz*0.14], [cx+sz*0.2, cy+sz*0.14]];
        let s = '';
        for (let i = 0; i < pts.length; i++)
          for (let j = i+1; j < pts.length; j++)
            s += `<line x1="${pts[i][0]}" y1="${pts[i][1]}" x2="${pts[j][0]}" y2="${pts[j][1]}" stroke="rgba(${c.stroke},0.12)" stroke-width="1.5"/>`;
        pts.forEach(p => s += `<circle cx="${p[0]}" cy="${p[1]}" r="${r}" fill="rgba(${c.fill},0.09)" stroke="rgba(${c.stroke},0.14)" stroke-width="1"/>`);
        return s;
      },
      blob(sz, c) {
        const m = sz/2, d = sz*0.38;
        const j = () => (Math.random()-0.5)*sz*0.12;
        return `<path d="M${m},${m-d} C${m+d+j()},${m-d*0.6+j()} ${m+d+j()},${m+d*0.6+j()} ${m},${m+d}
                         C${m-d*0.6+j()},${m+d+j()} ${m-d-j()},${m+d*0.3+j()} ${m-d},${m}
                         C${m-d-j()},${m-d*0.6+j()} ${m-d*0.4+j()},${m-d-j()} ${m},${m-d} Z"
                  fill="rgba(${c.fill},0.06)" stroke="rgba(${c.stroke},0.12)" stroke-width="1.5"/>`;
      },
      ring(sz, c) {
        const r = sz*0.4;
        return `<circle cx="${sz/2}" cy="${sz/2}" r="${r}" fill="none" stroke="rgba(${c.stroke},0.13)" stroke-width="2"/>
                <circle cx="${sz/2}" cy="${sz/2}" r="${r*0.6}" fill="none" stroke="rgba(${c.stroke},0.08)" stroke-width="1" stroke-dasharray="3 5"/>
                <circle cx="${sz/2 + r*0.25}" cy="${sz/2 - r*0.15}" r="${sz*0.05}" fill="rgba(${c.fill},0.10)"/>`;
      },
      arc(sz, c) {
        return `<path d="M${sz*0.15},${sz*0.6} Q${sz*0.5},${sz*0.05} ${sz*0.85},${sz*0.55}" fill="none" stroke="rgba(${c.stroke},0.12)" stroke-width="2" stroke-dasharray="3 8"/>
                <circle cx="${sz*0.15}" cy="${sz*0.6}" r="${sz*0.06}" fill="rgba(${c.fill},0.10)"/>
                <circle cx="${sz*0.85}" cy="${sz*0.55}" r="${sz*0.08}" fill="rgba(${c.fill},0.08)"/>`;
      },
      hex(sz, c) {
        const cx = sz/2, cy = sz/2, r = sz*0.3;
        let s = '';
        for (let i = 0; i < 6; i++) {
          const a1 = (Math.PI/3)*i - Math.PI/6, a2 = (Math.PI/3)*(i+1) - Math.PI/6;
          s += `<line x1="${cx+r*Math.cos(a1)}" y1="${cy+r*Math.sin(a1)}" x2="${cx+r*Math.cos(a2)}" y2="${cy+r*Math.sin(a2)}" stroke="rgba(${c.stroke},0.12)" stroke-width="1.5"/>`;
        }
        s += `<circle cx="${cx}" cy="${cy}" r="${sz*0.07}" fill="rgba(${c.fill},0.10)"/>`;
        return s;
      }
    };

    const shapeNames = Object.keys(shapes);
    const count = 35;
    for (let i = 0; i < count; i++) {
      const sz = 100 + Math.random() * 180; // 100-280px
      const shapeName = shapeNames[Math.floor(Math.random() * shapeNames.length)];
      const color = colors[Math.floor(Math.random() * colors.length)];
      const side = Math.random() < 0.5 ? 'left' : 'right';
      // Left margin: 0-15%, Right margin: 80-100%
      const x = side === 'left'
        ? Math.random() * 15
        : 80 + Math.random() * 20;
      const y = (i / count) * pageH + (Math.random() - 0.5) * (pageH / count) * 0.5;
      const rotation = Math.random() * 360;

      const svg = document.createElementNS('http://www.w3.org/2000/svg', 'svg');
      svg.setAttribute('width', sz);
      svg.setAttribute('height', sz);
      svg.setAttribute('viewBox', `0 0 ${sz} ${sz}`);
      svg.style.cssText = `left:${x}%;top:${y}px;width:${sz}px;height:${sz}px;transform:rotate(${rotation}deg);`;
      svg.innerHTML = shapes[shapeName](sz, color);
      container.appendChild(svg);
    }
  })();
</script>

