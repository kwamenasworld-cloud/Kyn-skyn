<!DOCTYPE html>
<html lang="{{ request.locale.iso_code }}">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <meta name="theme-color" content="#641220">
  <link rel="preconnect" href="https://cdn.shopify.com" crossorigin>
  {%- capture seo_title -%}
    {%- if template == 'index' -%}{{ shop.name }} — Skincare for Fungal Acne, Seb Derm & Malassezia-Prone Skin
    {%- elsif page_title contains shop.name -%}{{ page_title }}
    {%- else -%}{{ page_title }} — {{ shop.name }}
    {%- endif -%}
  {%- endcapture -%}
  {%- capture seo_description -%}
    {%- if template == 'index' -%}Skincare and telehealth for people with fungus-prone skin. Malassezia-safe formulas, an ingredient checker, and a clinician-backed handbook covering fungal acne, seborrheic dermatitis, dandruff, and tinea versicolor.
    {%- elsif page_description != blank -%}{{ page_description | escape }}
    {%- elsif page.content != blank -%}{{ page.content | strip_html | truncate: 160 | escape }}
    {%- else -%}{{ shop.description | default: "Skincare and telehealth for people with fungus-prone skin." | escape }}
    {%- endif -%}
  {%- endcapture -%}
  <title>{{ seo_title }}</title>
  <meta name="description" content="{{ seo_description }}">
  <link rel="canonical" href="{{ canonical_url }}">
  <meta property="og:site_name" content="{{ shop.name }}">
  <meta property="og:title" content="{{ seo_title }}">
  <meta property="og:description" content="{{ seo_description }}">
  {%- assign article_handles = 'handbook,fungal-acne' | split: ',' -%}
  <meta property="og:type" content="{% if article_handles contains page.handle %}article{% else %}website{% endif %}">
  <meta property="og:url" content="{{ canonical_url }}">
  <meta property="og:image" content="{{ 'chandani-closeup.jpg' | asset_url | prepend: 'https:' }}">
  <meta property="og:image:width" content="1200">
  <meta property="og:image:height" content="630">
  <meta property="og:locale" content="en_US">
  <meta name="twitter:card" content="summary_large_image">
  <meta name="twitter:site" content="@kynskyn">
  <meta name="twitter:creator" content="@kynskyn">
  <meta name="twitter:title" content="{{ seo_title }}">
  <meta name="twitter:description" content="{{ seo_description }}">
  <meta name="twitter:image" content="{{ 'chandani-closeup.jpg' | asset_url | prepend: 'https:' }}">
  <meta name="robots" content="index, follow, max-image-preview:large, max-snippet:-1">
  <link rel="icon" type="image/svg+xml" href="{{ 'logomark.svg' | asset_url }}">
  <link rel="alternate" type="application/rss+xml" title="{{ shop.name }}" href="{{ shop.url }}/blogs/news.atom">
  <link rel="sitemap" type="application/xml" href="{{ shop.url }}/sitemap.xml">
  <meta name="p:domain_verify" content="1f3e5bcbadcea3d6b041f467d71749d5"/>

  <script type="application/ld+json">
  {
    "@context": "https://schema.org",
    "@type": "Organization",
    "name": "Kyn Skyn",
    "alternateName": "Kyn Skyn Care",
    "url": "https://kynskyn.com",
    "logo": "https:{{ 'logomark.svg' | asset_url }}",
    "image": "https:{{ 'chandani-closeup.jpg' | asset_url }}",
    "description": "Skincare and telehealth for people with fungus-prone skin: fungal acne, seborrheic dermatitis, dandruff, and tinea versicolor.",
    "foundingDate": "2026",
    "knowsAbout": [
      "Malassezia folliculitis",
      "Fungal acne",
      "Seborrheic dermatitis",
      "Tinea versicolor",
      "Dandruff",
      "Pityrosporum folliculitis",
      "Sensitive skin care",
      "Teledermatology"
    ],
    "areaServed": {
      "@type": "Country",
      "name": "United States"
    },
    "contactPoint": [
      {
        "@type": "ContactPoint",
        "contactType": "customer support",
        "url": "https://kynskyn.com/pages/contact-1",
        "availableLanguage": "English"
      },
      {
        "@type": "ContactPoint",
        "contactType": "press",
        "email": "press@kynskyn.com",
        "availableLanguage": "English"
      }
    ],
    "sameAs": [
      "https://instagram.com/kynskyn",
      "https://tiktok.com/@kynskyn"
    ]
  }
  </script>

  <script type="application/ld+json">
  {
    "@context": "https://schema.org",
    "@type": "WebSite",
    "name": "Kyn Skyn",
    "url": "https://kynskyn.com",
    "inLanguage": "en-US",
    "publisher": {
      "@type": "Organization",
      "name": "Kyn Skyn",
      "logo": "https:{{ 'logomark.svg' | asset_url }}"
    },
    "potentialAction": {
      "@type": "SearchAction",
      "target": {
        "@type": "EntryPoint",
        "urlTemplate": "https://kynskyn.com/pages/ingredient-checker?q={search_term_string}"
      },
      "query-input": "required name=search_term_string"
    }
  }
  </script>

  {%- if template != 'index' and page.handle != blank -%}
  <script type="application/ld+json">
  {
    "@context": "https://schema.org",
    "@type": "BreadcrumbList",
    "itemListElement": [
      {
        "@type": "ListItem",
        "position": 1,
        "name": "Home",
        "item": "https://kynskyn.com/"
      },
      {
        "@type": "ListItem",
        "position": 2,
        "name": {{ page.title | json }},
        "item": {{ canonical_url | json }}
      }
    ]
  }
  </script>
  {%- endif -%}

  {{ content_for_header }}

  <style>
    /* ========== FONT FACES ========== */
    @font-face {
      font-family: 'STK Bureau Serif';
      src: url('{{ "STKBureauSerif-Light.woff2" | asset_url }}') format('woff2');
      font-weight: 300;
      font-style: normal;
      font-display: swap;
    }
    @font-face {
      font-family: 'STK Bureau Serif';
      src: url('{{ "STKBureauSerif-Book.woff2" | asset_url }}') format('woff2');
      font-weight: 400;
      font-style: normal;
      font-display: swap;
    }
    @font-face {
      font-family: 'STK Bureau Sans';
      src: url('{{ "STKBureauSans-Book.woff2" | asset_url }}') format('woff2');
      font-weight: 400;
      font-style: normal;
      font-display: swap;
    }
    @font-face {
      font-family: 'ABC Maxi Sharp';
      src: url('{{ "ABCMaxiSharp-Regular.woff2" | asset_url }}') format('woff2');
      font-weight: 400;
      font-style: normal;
      font-display: swap;
    }

    /* ========== RESET & BASE ========== */
    *, *::before, *::after { margin: 0; padding: 0; box-sizing: border-box; }

    :root {
      --cream: #fff4ce;
      --maroon: #641220;
      --dark: #2a0208;
      --button: #7e1029;
      --terracotta: #c75b2a;
      --gold: #d4952a;
      --font-serif: 'STK Bureau Serif', Georgia, serif;
      --font-sans: 'STK Bureau Sans', 'Helvetica Neue', Arial, sans-serif;
      --font-accent: 'ABC Maxi Sharp', 'STK Bureau Sans', sans-serif;
    }

    html {
      scroll-behavior: smooth;
      overflow-x: hidden;
      overflow-x: clip;
    }

    body {
      font-family: var(--font-sans);
      color: var(--maroon);
      background: var(--cream);
      -webkit-font-smoothing: antialiased;
      overflow-x: hidden;
      overflow-x: clip;
      position: relative;
      width: 100%;
    }

    main { overflow-x: hidden; overflow-x: clip; width: 100%; }

    /* ========== HEADER ========== */
    .site-header {
      position: fixed;
      top: 0; left: 0; right: 0;
      z-index: 100;
      padding: 1.5rem 3rem;
      display: flex;
      justify-content: space-between;
      align-items: center;
      transition: background 0.4s ease;
    }

    .site-header.scrolled {
      background: rgba(42, 2, 8, 0.92);
      backdrop-filter: blur(12px);
    }

    .header-nav {
      display: flex;
      gap: 2.5rem;
      list-style: none;
    }

    .header-nav a {
      color: var(--cream);
      text-decoration: none;
      font-family: var(--font-sans);
      font-size: 0.85rem;
      letter-spacing: 0.06em;
      text-transform: uppercase;
      opacity: 0.85;
      transition: opacity 0.3s;
    }

    .header-nav a:hover { opacity: 1; }

    .header-logo {
      position: absolute;
      left: 50%;
      transform: translateX(-50%);
      text-decoration: none;
      display: block;
    }

    .header-logo svg {
      height: 28px;
      width: auto;
      color: var(--cream);
      fill: var(--cream);
    }

    /* ========== HERO ========== */
    .hero {
      position: relative;
      min-height: 100vh;
      display: flex;
      align-items: flex-end;
      justify-content: flex-start;
      overflow: hidden;
    }

    .hero__bg {
      position: absolute;
      inset: 0;
      z-index: 0;
    }

    .hero__bg img {
      width: 100%;
      height: 100%;
      object-fit: cover;
      object-position: center top;
    }

    .hero__gradient {
      position: absolute;
      inset: 0;
      background: linear-gradient(
        to bottom,
        rgba(100, 18, 32, 0.0) 40%,
        rgba(42, 2, 8, 0.6) 70%,
        rgba(42, 2, 8, 0.92) 100%
      );
      z-index: 1;
    }

    .hero__content {
      position: relative;
      z-index: 2;
      padding: 0 3rem 5rem;
      max-width: 72rem;
    }

    .hero__badge {
      display: inline-block;
      font-family: var(--font-accent);
      font-size: 0.8rem;
      letter-spacing: 0.18em;
      text-transform: uppercase;
      color: var(--cream);
      margin-bottom: 1.8rem;
      border: 1.5px solid rgba(255, 244, 206, 0.45);
      padding: 0.6rem 1.6rem;
      border-radius: 2rem;
      background: rgba(42, 2, 8, 0.35);
      backdrop-filter: blur(6px);
    }

    .hero__heading {
      font-family: var(--font-serif);
      font-size: clamp(3rem, 7vw, 5.5rem);
      font-weight: 400;
      line-height: 1.05;
      color: var(--cream);
      margin-bottom: 1.2rem;
    }

    .hero__heading-plus {
      display: inline-block;
      color: var(--terracotta);
      font-family: var(--font-accent);
      font-weight: 400;
      font-size: 0.7em;
      line-height: 1;
      margin: 0 0.18em;
      vertical-align: 0.08em;
      transform-origin: 50% 55%;
      animation: heroPlusSpin 14s linear infinite;
    }

    @keyframes heroPlusSpin {
      from { transform: rotate(0deg); }
      to   { transform: rotate(360deg); }
    }

    @media (prefers-reduced-motion: reduce) {
      .hero__heading-plus { animation: none; transform: rotate(-8deg); }
    }

    .hero__sub {
      font-family: var(--font-sans);
      font-size: clamp(1rem, 2vw, 1.25rem);
      font-weight: 300;
      color: var(--cream);
      opacity: 0.85;
      max-width: 36rem;
      line-height: 1.6;
    }

    .hero__cta-wrap {
      position: relative;
      display: inline-block;
      margin-top: 2.5rem;
    }

    .hero__badge.hero__badge--sticker {
      position: absolute;
      top: -14px;
      left: -12px;
      transform: rotate(-7deg);
      transform-origin: center;
      z-index: 3;
      margin: 0;
      background: var(--dark);
      border-color: rgba(255, 244, 206, 0.35);
      font-size: 0.7rem;
      padding: 0.5rem 1.15rem;
      box-shadow: 0 6px 18px -6px rgba(42, 2, 8, 0.7);
      pointer-events: none;
      animation: stickerPop 0.6s cubic-bezier(0.34, 1.56, 0.64, 1) 0.5s both,
                 stickerWiggle 6s ease-in-out 2s infinite;
    }

    @keyframes stickerPop {
      from { opacity: 0; transform: rotate(-20deg) scale(0.7); }
      to   { opacity: 1; transform: rotate(-7deg) scale(1); }
    }

    @keyframes stickerWiggle {
      0%, 100% { transform: rotate(-7deg) translateY(0); }
      50%      { transform: rotate(-5deg) translateY(-2px); }
    }

    .hero__cta {
      position: relative;
      display: inline-flex;
      align-items: center;
      gap: 0.7rem;
      padding: 1.1rem 2rem 1.1rem 1.5rem;
      background: var(--cream);
      color: var(--maroon);
      font-family: var(--font-accent);
      font-size: 0.95rem;
      letter-spacing: 0.1em;
      text-transform: uppercase;
      text-decoration: none;
      border-radius: 999px;
      isolation: isolate;
      box-shadow: 0 10px 30px -10px rgba(42, 2, 8, 0.55);
      transition: transform 0.3s ease, box-shadow 0.3s ease;
      will-change: transform;
    }

    .hero__cta:hover {
      transform: translateY(-2px);
      box-shadow: 0 20px 40px -12px rgba(42, 2, 8, 0.7);
    }

    .hero__cta:focus-visible {
      outline: 2px solid var(--cream);
      outline-offset: 4px;
    }

    .hero__cta-dot {
      width: 0.5rem;
      height: 0.5rem;
      border-radius: 999px;
      background: var(--terracotta);
      box-shadow: 0 0 0 0 rgba(199, 91, 42, 0.55);
      animation: heroCtaPulse 2.2s ease-out infinite;
      flex-shrink: 0;
    }

    .hero__cta-arrow {
      width: 18px;
      height: 18px;
      transition: transform 0.3s ease;
      flex-shrink: 0;
    }

    .hero__cta:hover .hero__cta-arrow { transform: translateX(4px); }

    @keyframes heroCtaPulse {
      0%   { box-shadow: 0 0 0 0 rgba(199, 91, 42, 0.55); }
      70%  { box-shadow: 0 0 0 10px rgba(199, 91, 42, 0); }
      100% { box-shadow: 0 0 0 0 rgba(199, 91, 42, 0); }
    }

    @media (prefers-reduced-motion: reduce) {
      .hero__cta,
      .hero__cta-dot,
      .hero__cta-arrow { animation: none; transition: none; }
    }

    @media (max-width: 640px) {
      .hero__cta {
        font-size: 0.8rem;
        padding: 0.95rem 1.6rem 0.95rem 1.25rem;
        letter-spacing: 0.09em;
      }
    }

    /* ========== WAITLIST MODAL ========== */
    .waitlist-modal[hidden] { display: none; }
    .waitlist-modal {
      position: fixed;
      inset: 0;
      z-index: 1000;
      display: flex;
      align-items: center;
      justify-content: center;
      padding: 1.5rem;
      animation: waitlistFade 0.3s ease;
    }
    .waitlist-modal__backdrop {
      position: absolute;
      inset: 0;
      background: rgba(42, 2, 8, 0.72);
      backdrop-filter: blur(10px);
      cursor: pointer;
    }
    .waitlist-modal__panel {
      position: relative;
      z-index: 1;
      background: var(--cream);
      color: var(--maroon);
      border-radius: 24px;
      padding: 3rem 2.5rem 2.25rem;
      max-width: 28rem;
      width: 100%;
      box-shadow: 0 30px 80px -20px rgba(42, 2, 8, 0.65);
      text-align: center;
      animation: waitlistLift 0.45s cubic-bezier(0.16, 1, 0.3, 1);
    }
    .waitlist-modal__close {
      position: absolute;
      top: 0.6rem;
      right: 0.8rem;
      width: 2rem;
      height: 2rem;
      background: transparent;
      border: none;
      color: var(--maroon);
      opacity: 0.4;
      font-size: 1.6rem;
      line-height: 1;
      cursor: pointer;
      transition: opacity 0.2s;
    }
    .waitlist-modal__close:hover { opacity: 1; }
    .waitlist-modal__eyebrow {
      font-family: var(--font-accent);
      font-size: 0.7rem;
      letter-spacing: 0.22em;
      text-transform: uppercase;
      opacity: 0.5;
      margin: 0 0 1rem;
    }
    .waitlist-modal__title {
      font-family: var(--font-serif);
      font-size: clamp(1.8rem, 4vw, 2.3rem);
      font-weight: 400;
      line-height: 1.15;
      margin: 0 0 0.75rem;
    }
    .waitlist-modal__desc {
      font-family: var(--font-sans);
      font-size: 0.95rem;
      line-height: 1.6;
      opacity: 0.72;
      margin: 0 0 2rem;
    }
    .waitlist-modal__form {
      display: flex;
      flex-direction: column;
      gap: 0.75rem;
    }
    .waitlist-modal__input {
      font-family: var(--font-sans);
      font-size: 0.95rem;
      padding: 1rem 1.25rem;
      background: transparent;
      border: 1px solid rgba(100, 18, 32, 0.25);
      border-radius: 999px;
      color: var(--maroon);
      outline: none;
      transition: border-color 0.2s;
      text-align: center;
    }
    .waitlist-modal__input::placeholder { color: var(--maroon); opacity: 0.4; }
    .waitlist-modal__input:focus { border-color: var(--maroon); }
    .waitlist-modal__button {
      font-family: var(--font-accent);
      font-size: 0.85rem;
      letter-spacing: 0.12em;
      text-transform: uppercase;
      padding: 1rem 2rem;
      background: var(--maroon);
      color: var(--cream);
      border: none;
      border-radius: 999px;
      cursor: pointer;
      transition: background 0.2s, transform 0.2s;
    }
    .waitlist-modal__button:hover { background: var(--dark); transform: translateY(-1px); }
    .waitlist-modal__button:disabled { opacity: 0.7; cursor: wait; }
    .waitlist-modal__success {
      font-family: var(--font-sans);
      font-size: 0.9rem;
      color: var(--maroon);
      opacity: 0.8;
      margin: 1rem 0 0;
    }
    .waitlist-modal__legal {
      font-family: var(--font-sans);
      font-size: 0.7rem;
      letter-spacing: 0.02em;
      color: var(--maroon);
      opacity: 0.45;
      margin: 1.25rem 0 0;
    }

    @keyframes waitlistFade {
      from { opacity: 0; }
      to { opacity: 1; }
    }
    @keyframes waitlistLift {
      from { opacity: 0; transform: translateY(20px) scale(0.96); }
      to   { opacity: 1; transform: translateY(0) scale(1); }
    }

    @media (max-width: 640px) {
      .waitlist-modal__panel { padding: 2.5rem 1.75rem 2rem; border-radius: 20px; }
      .waitlist-modal__title { font-size: 1.6rem; }
    }

    /* ========== ABOUT SECTION ========== */
    .about {
      background: var(--cream);
      padding: 6rem 3rem;
      position: relative;
      overflow: hidden;
    }

    .about__molecule {
      position: absolute;
      top: 50%;
      left: 50%;
      transform: translate(-50%, -50%);
      width: 500px;
      height: auto;
      opacity: 0.04;
      filter: brightness(0);
      pointer-events: none;
      z-index: 0;
    }

    .about__container {
      max-width: 72rem;
      margin: 0 auto;
      display: grid;
      grid-template-columns: 1fr 1fr;
      gap: 4rem;
      align-items: center;
      position: relative;
      z-index: 1;
    }

    .about__eyebrow {
      font-family: var(--font-accent);
      font-size: 0.75rem;
      letter-spacing: 0.15em;
      text-transform: uppercase;
      color: var(--maroon);
      opacity: 0.6;
      margin-bottom: 1.5rem;
    }

    .about__heading {
      font-family: var(--font-serif);
      font-size: clamp(2.2rem, 4vw, 3.5rem);
      font-weight: 400;
      color: var(--maroon);
      margin-bottom: 2rem;
      line-height: 1.1;
    }

    .about__body {
      font-family: var(--font-sans);
      font-size: 1rem;
      line-height: 1.75;
      color: var(--maroon);
      opacity: 0.8;
    }

    .about__body p + p { margin-top: 1.2rem; }

    .about__mark {
      display: block;
      width: 3rem;
      height: 3rem;
      margin-top: 2rem;
      color: var(--maroon);
      opacity: 0.3;
    }

    .about__images {
      display: grid;
      grid-template-columns: 1fr 1fr;
      gap: 1rem;
      position: relative;
    }

    .about__image-wrap {
      position: relative;
      overflow: hidden;
      border-radius: 8px;
      cursor: pointer;
    }

    .about__image-wrap img {
      width: 100%;
      height: 100%;
      object-fit: cover;
      transition: filter 0.5s ease, transform 0.5s ease;
    }

    .about__image-wrap:hover img {
      filter: grayscale(1) brightness(0.4);
      transform: scale(1.03);
    }

    .about__image-overlay {
      position: absolute;
      inset: 0;
      display: flex;
      flex-direction: column;
      align-items: center;
      justify-content: center;
      text-align: center;
      padding: 1.5rem;
      opacity: 0;
      transition: opacity 0.5s ease;
      pointer-events: none;
    }

    .about__image-wrap:hover .about__image-overlay { opacity: 1; }

    .about__image-overlay-title {
      font-family: var(--font-serif);
      font-size: 1.4rem;
      color: var(--cream);
      margin-bottom: 0.6rem;
    }

    .about__image-overlay-sub {
      font-family: var(--font-sans);
      font-size: 0.7rem;
      letter-spacing: 0.1em;
      text-transform: uppercase;
      color: var(--cream);
      opacity: 0.7;
      line-height: 1.5;
    }

    .about__image-wrap.img-tall {
      grid-row: span 2;
      border-radius: 8px;
    }

    .about__images .img-square {
      border-radius: 8px;
      aspect-ratio: 1;
    }

    /* ========== HANDBOOK TEASER ========== */
    .handbook-teaser {
      background: var(--dark);
      padding: 6rem 3rem;
      position: relative;
      overflow: hidden;
    }

    .handbook-teaser__container {
      max-width: 72rem;
      margin: 0 auto;
      display: grid;
      grid-template-columns: 1fr 1fr;
      gap: 4rem;
      align-items: center;
    }

    .handbook-teaser__content {
      position: relative;
      z-index: 1;
    }

    .handbook-teaser__eyebrow {
      font-family: var(--font-accent);
      font-size: 0.75rem;
      letter-spacing: 0.15em;
      text-transform: uppercase;
      color: var(--cream);
      opacity: 0.5;
      margin-bottom: 1.5rem;
    }

    .handbook-teaser__heading {
      font-family: var(--font-serif);
      font-size: clamp(2.2rem, 4vw, 3.2rem);
      font-weight: 400;
      color: var(--cream);
      line-height: 1.15;
      margin-bottom: 1.5rem;
    }

    .handbook-teaser__desc {
      font-family: var(--font-sans);
      font-size: 1rem;
      line-height: 1.75;
      color: var(--cream);
      opacity: 0.7;
      margin-bottom: 2.5rem;
    }

    .handbook-teaser__topics {
      display: flex;
      flex-wrap: wrap;
      gap: 0.5rem;
      margin-bottom: 2.5rem;
    }

    .handbook-teaser__tag {
      font-family: var(--font-sans);
      font-size: 0.72rem;
      letter-spacing: 0.06em;
      text-transform: uppercase;
      color: var(--cream);
      opacity: 0.55;
      border: 1px solid rgba(255, 244, 206, 0.15);
      padding: 0.45rem 1rem;
      border-radius: 2rem;
    }

    .handbook-teaser__cta {
      display: inline-block;
      font-family: var(--font-sans);
      font-size: 0.85rem;
      letter-spacing: 0.08em;
      text-transform: uppercase;
      color: var(--cream);
      background: var(--button);
      padding: 1rem 2.5rem;
      border-radius: 4px;
      text-decoration: none;
      transition: background 0.3s;
    }

    .handbook-teaser__cta:hover {
      background: var(--maroon);
    }

    .handbook-teaser__visual {
      position: relative;
      display: flex;
      flex-direction: column;
      gap: 1rem;
    }

    .handbook-teaser__preview {
      background: rgba(255, 244, 206, 0.04);
      border: 1px solid rgba(255, 244, 206, 0.08);
      border-radius: 8px;
      padding: 2rem 2.5rem;
    }

    .handbook-teaser__preview-label {
      font-family: var(--font-accent);
      font-size: 0.65rem;
      letter-spacing: 0.15em;
      text-transform: uppercase;
      color: var(--cream);
      opacity: 0.35;
      margin-bottom: 1rem;
    }

    .handbook-teaser__preview-item {
      display: flex;
      align-items: baseline;
      gap: 0.8rem;
      padding: 0.6rem 0;
      border-bottom: 1px solid rgba(255, 244, 206, 0.06);
    }

    .handbook-teaser__preview-item:last-child {
      border-bottom: none;
    }

    .handbook-teaser__preview-num {
      font-family: var(--font-serif);
      font-size: 1.3rem;
      color: var(--cream);
      opacity: 0.25;
      min-width: 1.5rem;
    }

    .handbook-teaser__preview-title {
      font-family: var(--font-sans);
      font-size: 0.9rem;
      color: var(--cream);
      opacity: 0.65;
    }

    /* ========== NOTIFY ========== */
    .notify {
      background: var(--dark);
      padding: 8rem 3rem;
      position: relative;
      overflow: hidden;
    }

    .notify__grid-bg {
      position: absolute;
      inset: 0;
      opacity: 0.06;
      display: flex;
      align-items: center;
      justify-content: center;
    }

    .notify__grid-bg svg {
      width: 60%;
      height: auto;
      color: var(--cream);
    }

    .notify__container {
      max-width: 48rem;
      margin: 0 auto;
      text-align: center;
      position: relative;
      z-index: 2;
    }

    .notify__eyebrow {
      font-family: var(--font-accent);
      font-size: 0.75rem;
      letter-spacing: 0.2em;
      text-transform: uppercase;
      color: var(--cream);
      opacity: 0.5;
      margin-bottom: 2rem;
    }

    .notify__heading {
      font-family: var(--font-serif);
      font-size: clamp(2.5rem, 5vw, 4.5rem);
      font-weight: 400;
      color: var(--cream);
      line-height: 1.1;
      margin-bottom: 1.5rem;
    }

    .notify__desc {
      font-family: var(--font-sans);
      font-size: 1.1rem;
      color: var(--cream);
      opacity: 0.7;
      line-height: 1.7;
      margin-bottom: 3rem;
      max-width: 32rem;
      margin-left: auto;
      margin-right: auto;
    }

    .notify__form {
      display: flex;
      gap: 0;
      max-width: 28rem;
      margin: 0 auto;
      border: 1px solid rgba(255, 244, 206, 0.2);
      border-radius: 4px;
      overflow: hidden;
      transition: border-color 0.3s;
    }

    .notify__form:focus-within { border-color: rgba(255, 244, 206, 0.5); }

    .notify__input {
      flex: 1;
      background: transparent;
      border: none;
      padding: 1rem 1.5rem;
      color: var(--cream);
      font-family: var(--font-sans);
      font-size: 0.9rem;
      outline: none;
    }

    .notify__input::placeholder { color: rgba(255, 244, 206, 0.4); }

    .notify__button {
      background: var(--button);
      color: var(--cream);
      border: none;
      padding: 1rem 2rem;
      font-family: var(--font-sans);
      font-size: 0.8rem;
      letter-spacing: 0.1em;
      text-transform: uppercase;
      cursor: pointer;
      transition: background 0.3s;
      white-space: nowrap;
    }

    .notify__button:hover { background: var(--maroon); }

    /* ========== CONTACT ========== */
    .contact-page {
      padding-top: 7rem;
      min-height: 100vh;
      display: flex;
      flex-direction: column;
    }

    .contact {
      background: var(--cream);
      padding: 4rem 3rem 6rem;
      flex: 1;
    }

    .contact__container {
      max-width: 42rem;
      margin: 0 auto;
      text-align: center;
    }

    .contact__eyebrow {
      font-family: var(--font-accent);
      font-size: 0.75rem;
      letter-spacing: 0.15em;
      text-transform: uppercase;
      color: var(--maroon);
      opacity: 0.6;
      margin-bottom: 1.2rem;
    }

    .contact__heading {
      font-family: var(--font-serif);
      font-size: clamp(2rem, 4vw, 3rem);
      font-weight: 300;
      color: var(--maroon);
      line-height: 1.15;
      margin-bottom: 1rem;
    }

    .contact__desc {
      font-family: var(--font-sans);
      font-size: 0.95rem;
      color: var(--maroon);
      opacity: 0.65;
      line-height: 1.7;
      max-width: 32rem;
      margin: 0 auto 3rem;
    }

    .contact__type-selector {
      display: flex;
      gap: 0.75rem;
      justify-content: center;
      margin-bottom: 2.5rem;
      flex-wrap: wrap;
    }

    .contact__type-btn {
      font-family: var(--font-sans);
      font-size: 0.8rem;
      letter-spacing: 0.06em;
      text-transform: uppercase;
      padding: 0.7rem 1.5rem;
      border: 1px solid rgba(100, 18, 32, 0.25);
      border-radius: 4px;
      background: transparent;
      color: var(--maroon);
      cursor: pointer;
      transition: all 0.3s ease;
    }

    .contact__type-btn:hover {
      border-color: var(--maroon);
      background: rgba(100, 18, 32, 0.05);
    }

    .contact__type-btn.active {
      background: var(--maroon);
      color: var(--cream);
      border-color: var(--maroon);
    }

    .contact__form {
      display: flex;
      flex-direction: column;
      gap: 1rem;
      text-align: left;
    }

    .contact__row {
      display: flex;
      gap: 1rem;
    }

    .contact__field {
      flex: 1;
      font-family: var(--font-sans);
      font-size: 0.9rem;
      color: var(--maroon);
      background: transparent;
      border: 1px solid rgba(100, 18, 32, 0.2);
      border-radius: 4px;
      padding: 1rem 1.2rem;
      outline: none;
      transition: border-color 0.3s;
    }

    .contact__field::placeholder {
      color: var(--maroon);
      opacity: 0.35;
    }

    .contact__field:focus {
      border-color: rgba(100, 18, 32, 0.5);
    }

    textarea.contact__field {
      resize: vertical;
      min-height: 8rem;
    }

    .contact__submit {
      font-family: var(--font-sans);
      font-size: 0.8rem;
      letter-spacing: 0.1em;
      text-transform: uppercase;
      padding: 1rem 2.5rem;
      background: var(--button);
      color: var(--cream);
      border: none;
      border-radius: 4px;
      cursor: pointer;
      transition: background 0.3s;
      align-self: flex-start;
    }

    .contact__submit:hover {
      background: var(--maroon);
    }

    .contact__submit:disabled {
      opacity: 0.6;
      cursor: not-allowed;
    }

    .contact__confirmation {
      display: none;
      font-family: var(--font-sans);
      font-size: 0.9rem;
      color: var(--maroon);
      opacity: 0.8;
      margin-top: 1rem;
    }

    /* ========== FOOTER ========== */
    .site-footer {
      background: var(--dark);
      padding: 5rem 3rem 2.5rem;
      border-top: 1px solid rgba(255, 244, 206, 0.06);
    }

    .footer__container { max-width: 72rem; margin: 0 auto; }

    .footer__top {
      display: flex;
      justify-content: space-between;
      align-items: flex-start;
      padding-bottom: 3rem;
      border-bottom: 1px solid rgba(255, 244, 206, 0.1);
    }

    .footer__logo svg { height: 24px; color: var(--cream); fill: var(--cream); }

    .footer__nav { display: flex; gap: 2rem; list-style: none; }

    .footer__nav a {
      color: var(--cream);
      text-decoration: none;
      font-family: var(--font-sans);
      font-size: 0.8rem;
      letter-spacing: 0.06em;
      text-transform: uppercase;
      opacity: 0.6;
      transition: opacity 0.3s;
    }

    .footer__nav a:hover { opacity: 1; }

    .footer__social { display: flex; gap: 1.2rem; }
    .footer__social a { color: var(--cream); opacity: 0.5; transition: opacity 0.3s; }
    .footer__social a:hover { opacity: 1; }
    .footer__social svg { width: 18px; height: 18px; }

    .footer__bottom {
      padding-top: 2rem;
      display: flex;
      justify-content: space-between;
      align-items: center;
    }

    .footer__copy {
      font-family: var(--font-sans);
      font-size: 0.7rem;
      color: var(--cream);
      opacity: 0.3;
      letter-spacing: 0.04em;
    }

    /* ========== MOBILE TAB BAR ========== */
    .mobile-tab-bar {
      display: none;
      position: fixed;
      bottom: 0; left: 0; right: 0;
      z-index: 200;
      background: var(--dark);
      border-top: 1px solid rgba(255, 244, 206, 0.08);
      padding: 0.5rem 0 calc(0.5rem + env(safe-area-inset-bottom, 0px));
    }
    .mobile-tab-bar__links { display: flex; justify-content: space-around; align-items: center; list-style: none; padding: 0 0.25rem; }
    .mobile-tab-bar__link { display: flex; flex-direction: column; align-items: center; gap: 0.2rem; text-decoration: none; color: var(--cream); opacity: 0.45; transition: opacity 0.2s; padding: 0.3rem 0.2rem; flex: 1 1 0; min-width: 0; }
    .mobile-tab-bar__link.active { opacity: 1; }
    .mobile-tab-bar__link svg { width: 20px; height: 20px; flex-shrink: 0; }
    .mobile-tab-bar__label { font-family: var(--font-sans); font-size: 0.58rem; letter-spacing: 0.04em; text-transform: uppercase; white-space: nowrap; max-width: 100%; overflow: hidden; text-overflow: ellipsis; }

    /* ========== RESPONSIVE ========== */
    @media (max-width: 768px) {
      .site-header { padding: 1.2rem 1.5rem; }
      .header-nav { display: none; }
      .mobile-tab-bar { display: block; }
      body { padding-bottom: 4.5rem; }
      .hero__content { padding: 0 1.5rem 3rem; }
      .about { padding: 4rem 1.5rem; }
      .about__container { grid-template-columns: 1fr; gap: 3rem; }
      .handbook-teaser { padding: 4rem 1.5rem; }
      .handbook-teaser__container { grid-template-columns: 1fr; gap: 3rem; }
      .notify { padding: 5rem 1.5rem; }
      .notify__form { flex-direction: column; }
      .notify__button { padding: 1rem; }
      .contact { padding: 3rem 1.5rem 4rem; }
      .contact__row { flex-direction: column; }
      .contact__type-selector { gap: 0.5rem; }
      .contact__type-btn { padding: 0.6rem 1.2rem; font-size: 0.75rem; }
      .contact__submit { align-self: stretch; }
      .site-footer { padding: 3rem 1.5rem 1.5rem; }
      .footer__top { flex-direction: column; gap: 2rem; }
      .footer__bottom { flex-direction: column; gap: 1rem; }
    }

    /* ========== ANIMATIONS ========== */
    .fade-in {
      opacity: 0;
      transform: translateY(30px);
      transition: opacity 0.8s ease, transform 0.8s ease;
    }
    .fade-in.visible { opacity: 1; transform: translateY(0); }

    @keyframes heroFadeUp {
      from { opacity: 0; transform: translateY(40px); }
      to { opacity: 1; transform: translateY(0); }
    }
    .hero__badge { animation: heroFadeUp 0.8s ease 0.3s both; }
    .hero__heading { animation: heroFadeUp 0.8s ease 0.5s both; }
    .hero__sub { animation: heroFadeUp 0.8s ease 0.7s both; }

    .site-header::before {
      content: '';
      position: absolute;
      inset: 0;
      background: linear-gradient(to bottom, rgba(42, 2, 8, 0.5), transparent);
      z-index: -1;
      pointer-events: none;
      transition: opacity 0.4s;
    }
    .site-header.scrolled::before { opacity: 0; }
  </style>
</head>
<body>
  {% section 'header' %}
  <main>
    {{ content_for_layout }}
  </main>
  {% section 'footer' %}

  <script>
    // Header scroll effect
    const header = document.getElementById('siteHeader');
    window.addEventListener('scroll', () => {
      header.classList.toggle('scrolled', window.scrollY > 60);
    });

    // Scroll fade-in
    const fadeEls = document.querySelectorAll('.fade-in');
    const observer = new IntersectionObserver((entries) => {
      entries.forEach(entry => {
        if (entry.isIntersecting) entry.target.classList.add('visible');
      });
    }, { threshold: 0.15 });
    fadeEls.forEach(el => observer.observe(el));
  </script>

  <!-- ====== MOBILE TAB BAR ====== -->
  <nav class="mobile-tab-bar">
    <ul class="mobile-tab-bar__links">
      <li>
        <a href="/" class="mobile-tab-bar__link{% if request.path == '/' %} active{% endif %}">
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M3 9l9-7 9 7v11a2 2 0 01-2 2H5a2 2 0 01-2-2z"/><polyline points="9 22 9 12 15 12 15 22"/></svg>
          <span class="mobile-tab-bar__label">Home</span>
        </a>
      </li>
      <li>
        <a href="/pages/handbook" class="mobile-tab-bar__link{% if request.path contains 'handbook' %} active{% endif %}">
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M4 19.5A2.5 2.5 0 016.5 17H20"/><path d="M6.5 2H20v20H6.5A2.5 2.5 0 014 19.5v-15A2.5 2.5 0 016.5 2z"/></svg>
          <span class="mobile-tab-bar__label">Handbook</span>
        </a>
      </li>
      <li>
        <a href="/pages/ingredient-checker" class="mobile-tab-bar__link{% if request.path contains 'ingredient-checker' %} active{% endif %}">
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M9 5H7a2 2 0 00-2 2v12a2 2 0 002 2h10a2 2 0 002-2V7a2 2 0 00-2-2h-2"/><rect x="9" y="3" width="6" height="4" rx="1"/><path d="M9 14l2 2 4-4"/></svg>
          <span class="mobile-tab-bar__label">Checker</span>
        </a>
      </li>
      <li>
        <a href="/pages/consultation" class="mobile-tab-bar__link{% if request.path contains 'consultation' %} active{% endif %}">
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><polygon points="23 7 16 12 23 17 23 7"/><rect x="1" y="5" width="15" height="14" rx="2" ry="2"/></svg>
          <span class="mobile-tab-bar__label">Consult</span>
        </a>
      </li>
      <li>
        <a href="/pages/contact-1" class="mobile-tab-bar__link{% if request.path contains 'contact' %} active{% endif %}">
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M21 15a2 2 0 01-2 2H7l-4 4V5a2 2 0 012-2h14a2 2 0 012 2z"/></svg>
          <span class="mobile-tab-bar__label">Contact</span>
        </a>
      </li>
    </ul>
  </nav>

</body>
</html>
